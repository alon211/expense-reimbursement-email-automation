{
  "parse_time_range_days": 2
,
  "rules": [
    {
      "rule_id": "rule_001",
      "rule_name": "报销邮件提取",
      "enabled": false,
      "description": "提取包含报销、费用、发票关键词的邮件",
      "match_conditions": {
        "sender_contains": [
          "finance",
          "报销",
          "财务"
        ],
        "subject_contains": [
          "报销",
          "费用",
          "发票"
        ],
        "body_contains": [
          "发票",
          "报销单",
          "费用清单"
        ]
      },
      "extract_options": {
        "extract_attachments": true,
        "extract_body": true,
        "extract_headers": true
      },
      "output_subdir": "reimbursement"
    },
    {
      "rule_id": "rule_002",
      "rule_name": "12306提取",
      "enabled": false,
      "description": "提取指定地址邮件",
      "match_conditions": {
        "sender_contains": [
          "12306",
          "didifapiao",
          "reservation",
          "诺诺网"
        ],
        "subject_contains": [
          "高德打车电子发票"
        ],
        "body_contains": []
      },
      "extract_options": {
        "extract_attachments": true,
        "extract_body": false,
        "extract_headers": false,
        "extract_archives": true,
        "archive_password": "",
        "extract_nuonuo_invoice": true,
        "nuonuo_anchor_text": "点击链接查看发票：",
        "nuonuo_download_options": {
          "timeout": 10,
          "verify_ssl": true
        },
        "allowed_archive_types": [
          ".zip",
          ".rar",
          ".7z",
          ".tar.gz",
          ".tar.bz2"
        ]
      },
      "output_subdir": "12306"
    },
    {
      "rule_id": "rule_003",
      "rule_name": "诺诺网发票提取",
      "enabled": true,
      "description": "从诺诺网发票邮件中自动提取并下载PDF",
      "match_conditions": {
        "sender_contains": [
          "诺诺网"
        ],
        "subject_contains": [
          "发票"
        ],
        "body_contains": []
      },
      "extract_options": {
        "extract_attachments": false,
        "extract_body": true,
        "extract_headers": false,
        "extract_archives": false,
        "extract_nuonuo_invoice": true,
        "nuonuo_anchor_text": "点击链接查看发票：",
        "nuonuo_download_options": {
          "timeout": 10,
          "verify_ssl": true
        }
      },
      "output_subdir": "invoices"
    }
  ]
}
