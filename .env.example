# ===================== 邮箱配置 =====================
IMAP_HOST=imap.qq.com
IMAP_USER=your_email@example.com
IMAP_PASS=your_password
MAIL_CHECK_FOLDER=INBOX
# 搜索条件：UNSEEN(仅未读) 或 ALL(所有邮件，包括已读)
MAIL_SEARCH_CRITERIA=ALL

# ===================== 定时配置 =====================
CHECK_INTERVAL=60
TIME_ZONE=Asia/Shanghai
# 是否只执行一次（True=执行一次后退出，False=循环运行）
RUN_ONCE=False

# ===================== 日志配置 =====================
LOG_LEVEL=DEBUG
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5
LOG_DIR=./logs

# ===================== 推送配置（钉钉） =====================
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your_token
DINGTALK_SECRET=your_secret
PUSH_SWITCH=True

# ===================== 解析规则 & 存储配置 =====================
# 邮件解析规则JSON文件路径
PARSE_RULES_JSON_PATH=./rules/parse_rules.json
# 提取内容根文件夹路径
EXTRACT_ROOT_DIR=./extracted_mails
# 是否在启动时清空数据库（True=清空，False=保留）
# 警告：设置为 True 会删除所有已提取的邮件记录，仅用于开发和测试
CLEAR_DB_ON_STARTUP=False
